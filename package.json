{
  "name": "cubid-sdk",
  "private": true,
  "version": "0.0.0",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r build",
    "check:core-package": "pnpm --filter @cubid/core pack:dry-run && pnpm --filter @cubid/core jsr:dry-run",
    "changeset": "changeset",
    "deno:check:core": "pnpm --filter @cubid/core deno:check",
    "lint": "eslint .",
    "release": "changeset publish",
    "test": "pnpm --filter @cubid/core test && vitest run",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.4",
    "@eslint/js": "^9.25.1",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.7.2",
    "@types/react": "^19.1.3",
    "@types/react-dom": "^19.1.3",
    "eslint": "^9.25.1",
    "globals": "^16.0.0",
    "jsdom": "^26.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "vitest": "^3.1.2"
  }
}
