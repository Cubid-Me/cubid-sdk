{
  "name": "cubid-sdk",
  "private": true,
  "version": "0.0.0",
  "license": "Apache-2.0",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "build": "pnpm -r build",
    "check:core-package": "pnpm --filter @cubid/core pack:dry-run && pnpm --filter @cubid/core jsr:dry-run",
    "changeset": "changeset",
    "deno:check:core": "pnpm --filter @cubid/core deno:check",
    "docs:api:build": "node scripts/build-api-reference.mjs",
    "docs:api:check": "node scripts/build-api-reference.mjs --check",
    "lint": "eslint .",
    "release": "changeset publish",
    "test": "pnpm test:unit && pnpm build && pnpm test:acceptance",
    "test:acceptance": "pnpm --filter @cubid/acceptance test",
    "test:coverage": "vitest run --config vitest.config.ts --coverage",
    "test:unit": "pnpm --filter @cubid/core build && pnpm --filter @cubid/auth build && pnpm --filter @cubid/browser build && pnpm --filter @cubid/evm build && pnpm --filter @cubid/near build && pnpm --filter @cubid/solana build && vitest run --config vitest.config.ts",
    "typecheck": "pnpm -r typecheck"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.4",
    "@eslint/js": "^9.25.1",
    "@tanstack/react-query": "^5.100.8",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^24.7.2",
    "@types/react": "^19.1.3",
    "@types/react-dom": "^19.1.3",
    "@vitest/coverage-v8": "^3.1.2",
    "eslint": "^9.25.1",
    "globals": "^16.0.0",
    "jsdom": "^26.1.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "typedoc": "^0.28.14",
    "tsup": "^8.4.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.30.1",
    "viem": "2.48.8",
    "vitest": "^3.1.2",
    "wagmi": "3.6.9"
  }
}
