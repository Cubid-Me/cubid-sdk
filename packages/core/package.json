{
  "name": "@cubid/core",
  "version": "0.2.0",
  "description": "Runtime-agnostic Cubid core client for server-side integrations.",
  "type": "module",
  "license": "Apache-2.0",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md",
    "jsr.json"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Cubid-Me/cubid-sdk.git",
    "directory": "packages/core"
  },
  "homepage": "https://github.com/Cubid-Me/cubid-sdk/tree/main/packages/core",
  "bugs": {
    "url": "https://github.com/Cubid-Me/cubid-sdk/issues"
  },
  "keywords": [
    "cubid",
    "identity",
    "proof-of-personhood",
    "sdk",
    "supabase-edge",
    "deno"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\" && pnpm exec tsc -p tsconfig.build.json",
    "lint": "pnpm exec tsc --noEmit -p tsconfig.json",
    "typecheck": "pnpm exec tsc --noEmit -p tsconfig.json",
    "test": "pnpm --dir ../.. exec vitest run --config vitest.config.ts packages/core/src/index.test.ts",
    "deno:check": "deno check --no-lock deno/supabase-edge-smoke.ts",
    "pack:dry-run": "npm pack --dry-run",
    "jsr:dry-run": "pnpm dlx jsr publish --dry-run --allow-dirty",
    "format": "echo \"No format changes required for @cubid/core\"",
    "format:write": "echo \"No format changes required for @cubid/core\""
  },
  "devDependencies": {
    "@types/node": "^24.0.0",
    "typescript": "5.2.2"
  }
}
