{
  "name": "@cubid/auth-react",
  "version": "0.1.0",
  "description": "React session bindings and components for Sign in with Cubid.",
  "license": "Apache-2.0",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    }
  },
  "files": ["dist", "README.md", "LICENSE"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Cubid-Me/cubid-sdk.git",
    "directory": "packages/auth-react"
  },
  "homepage": "https://github.com/Cubid-Me/cubid-sdk/tree/main/packages/auth-react",
  "bugs": {
    "url": "https://github.com/Cubid-Me/cubid-sdk/issues"
  },
  "keywords": [
    "cubid",
    "auth",
    "react",
    "oidc",
    "pkce",
    "sdk"
  ],
  "sideEffects": false,
  "dependencies": {
    "@cubid/auth": "workspace:*"
  },
  "peerDependencies": {
    "react": ">=18.2.0",
    "react-dom": ">=18.2.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup src/index.ts --dts --format cjs,esm --clean --external react --external react-dom",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  }
}
