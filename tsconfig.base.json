{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "baseUrl": ".",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "jsx": "react-jsx",
    "strict": true,
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "isolatedModules": true,
    "noImplicitOverride": true,
    "noUncheckedIndexedAccess": true,
    "paths": {
      "@cubid/auth": ["packages/auth/src/index.ts"],
      "@cubid/auth-react": ["packages/auth-react/src/index.ts"],
      "@cubid/browser": ["packages/browser/src/index.ts"],
      "@cubid/bitcoin": ["packages/bitcoin/src/index.ts"],
      "@cubid/cardano": ["packages/cardano/src/index.ts"],
      "@cubid/core": ["packages/core/src/index.ts"],
      "@cubid/cosmos": ["packages/cosmos/src/index.ts"],
      "@cubid/evm": ["packages/evm/src/index.ts"],
      "@cubid/near": ["packages/near/src/index.ts"],
      "@cubid/react": ["packages/react/src/index.ts"],
      "@cubid/solana": ["packages/solana/src/index.ts"],
      "@cubid/starknet": ["packages/starknet/src/index.ts"],
      "@cubid/sui": ["packages/sui/src/index.ts"],
      "@cubid/wagmi": ["packages/wagmi/src/index.ts"],
      "@cubid/web2": ["packages/web2/src/index.ts"],
      "@cubid/web2-react": ["packages/web2-react/src/index.ts"],
      "@cubid/web3": ["packages/web3/src/index.ts"]
    },
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "useDefineForClassFields": true
  }
}
